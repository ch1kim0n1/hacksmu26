# EchoField — Environment Variables
# Copy this to .env and fill in your values
#
# EchoField: Elephant vocalization noise-removal platform
# Detects and denoise elephant calls from field recordings

# === Audio Processing ===

# Directory containing upload/default input recordings.
# In demo mode, if this directory is empty, the loader falls back to ./data/audio-files.
ECHOFIELD_AUDIO_DIR=./data/recordings

# Persistent recording catalog used to keep IDs/status/results stable across restarts
ECHOFIELD_CATALOG_FILE=./data/cache/recording_catalog.json

# Directory for processed (denoised) audio output
ECHOFIELD_OUTPUT_DIR=./data/processed

# CSV file containing audio metadata (filename, species, location, date, etc.)
ECHOFIELD_METADATA_FILE=./data/metadata.csv

# === ML Pipeline Configuration ===

# Enable GPU acceleration (requires CUDA 11.8+)
ECHOFIELD_USE_GPU=false

# Denoise method: "spectral" (FFT-based), "deep" (neural net), "hybrid" (both)
ECHOFIELD_DENOISE_METHOD=hybrid

# Spectral denoising: noise gate threshold in standard deviations
# Higher = more aggressive (removes more non-elephant content)
# Recommended: 1.2-2.0 (we use 1.5 as sweet spot)
ECHOFIELD_SPECTRAL_THRESHOLD=1.5

# Audio frequency range constraints
# Elephant infrasound fundamentals: 8-35 Hz (below human hearing)
# Audible harmonics extend to ~1200 Hz (trumpet-like quality)
ECHOFIELD_MIN_FREQUENCY=8
ECHOFIELD_MAX_FREQUENCY=1200

# Spectrogram parameters (FFT analysis)
# Window size affects time-frequency trade-off
ECHOFIELD_SPECTROGRAM_WINDOW_SIZE=4096
# Overlap (hop) controls granularity — lower = finer detail
ECHOFIELD_SPECTROGRAM_HOP_LENGTH=1024

# === Deep Learning Model ===

# Path to pre-trained denoising model weights
ECHOFIELD_MODEL_PATH=./models/echofield-denoise-v1.pt

# Model architecture: "unet", "conformer", or "separator"
ECHOFIELD_MODEL_ARCHITECTURE=unet

# Inference batch size (higher = faster but more memory)
ECHOFIELD_BATCH_SIZE=8

# === Server Configuration ===

# FastAPI backend port
ECHOFIELD_BACKEND_PORT=8000

# Next.js frontend port
ECHOFIELD_FRONTEND_PORT=3000

# Frontend URL (for CORS, cross-origin requests)
ECHOFIELD_FRONTEND_URL=http://localhost:3000

# === LLM Integration (optional — for research summaries) ===

# Google Gemini API key (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# LLM provider: "google" (Gemini)
ECHOFIELD_LLM_PROVIDER=google

# Model for generating research insights and metadata descriptions
ECHOFIELD_LLM_MODEL=gemini-2.0-flash

# === Data Caching ===

# Redis host (for job queue and audio processing cache)
ECHOFIELD_REDIS_HOST=localhost
ECHOFIELD_REDIS_PORT=6379

# Cache TTL for processed audio (seconds)
ECHOFIELD_CACHE_TTL=3600

# === Logging ===

# Log level: DEBUG, INFO, WARNING, ERROR
ECHOFIELD_LOG_LEVEL=INFO

# Log output format: "text" or "json"
ECHOFIELD_LOG_FORMAT=text

# === Database ===

# SQLite database file for metadata and job tracking
ECHOFIELD_DB_PATH=./echofield.db

# === Security ===

# API key for protected endpoints (optional)
ECHOFIELD_API_KEY=your_api_key_here

# Enable demo mode (adds mock endpoints for testing)
ECHOFIELD_DEMO_MODE=true
