# EchoField runtime defaults
ECHOFIELD_AUDIO_DIR=./data/recordings
ECHOFIELD_PROCESSED_DIR=./data/processed
ECHOFIELD_SPECTROGRAM_DIR=./data/spectrograms
ECHOFIELD_METADATA_FILE=./data/metadata.csv
ECHOFIELD_CONFIG_FILE=./config/echofield.config.yml
ECHOFIELD_CACHE_DIR=./data/cache
ECHOFIELD_MODEL_PATH=./models/echofield-denoise-v1.pt

# API
ECHOFIELD_API_PORT=8000
ECHOFIELD_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ECHOFIELD_LOG_LEVEL=INFO
ECHOFIELD_LOG_FORMAT=text
ECHOFIELD_DEMO_MODE=true

# Auth0 backend auth (disabled by default for local demos)
ECHOFIELD_AUTH_ENABLED=false
# ECHOFIELD_AUTH0_DOMAIN=your-tenant.us.auth0.com
# ECHOFIELD_AUTH0_AUDIENCE=https://api.echofield.local
# ECHOFIELD_AUTH0_ALGORITHMS=RS256
# ECHOFIELD_AUTH0_CLIENT_ID=your-auth0-application-client-id
# ECHOFIELD_AUTH0_CLIENT_SECRET=your-auth0-application-client-secret
# ECHOFIELD_AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
# ECHOFIELD_AUTH0_DEFAULT_SCOPE=openid profile email
# ECHOFIELD_AUTH0_SOCIAL_CONNECTIONS=google-oauth2,github
# ECHOFIELD_AUTH0_ENTERPRISE_CONNECTIONS=waad,samlp
# ECHOFIELD_AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/
# ECHOFIELD_AUTH0_ROLES_CLAIM=https://echofield.dev/roles
# ECHOFIELD_AUTH_PUBLIC_PATHS=/health,/metrics,/docs,/redoc,/openapi.json,/api/auth/config,/api/auth/login-url,/api/auth/token,/api/auth/passwordless,/api/auth/mfa

# Pipeline defaults
ECHOFIELD_SAMPLE_RATE=44100
ECHOFIELD_SEGMENT_SECONDS=60
ECHOFIELD_SEGMENT_OVERLAP_RATIO=0.5
ECHOFIELD_DENOISE_METHOD=hybrid
ECHOFIELD_SPECTROGRAM_N_FFT=2048
ECHOFIELD_SPECTROGRAM_HOP_LENGTH=512
ECHOFIELD_SPECTROGRAM_FREQ_MAX=1000
